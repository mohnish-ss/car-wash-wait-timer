{
  "version": 2,
  "buildCommand": "cd server && npm install && npx tsc",
  "outputDirectory": "server/public",
  "rewrites": [
    {
      "source": "/",
      "destination": "/api"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api"
    }
  ],
  "functions": {
    "api/index.ts": {
      "includeFiles": "server/**"
    }
  }
}